<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Register Page</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        background:#141414;
        color:white;
    }

    .navbar{
        width:100%;
        padding:15px 40px;
        background:#000;
        display:flex;
        justify-content:space-between;
        align-items:center;
        position:sticky;
        top:0;
    }

    .logo{
        color:#e50914;
        font-size:26px;
        font-weight:bold;
        letter-spacing:1px;
    }

    .nav-link a{
        color:white;
        text-decoration:none;
        margin-left:15px;
        font-size:14px;
    }

    .nav-link a:hover{
        color:#e50914;
    }

    .container{
        width:380px;
        background:rgba(0,0,0,0.75);
        padding:40px;
        border-radius:10px;
        margin:80px auto;
        box-shadow:0 0 20px rgba(0,0,0,0.6);
    }

    h2{
        text-align:left;
        color:white;
        margin-bottom:25px;
        font-size:28px;
    }

    .input-group{
        margin-bottom:15px;
    }

    label{
        display:block;
        color:#aaa;
        margin-bottom:6px;
        font-size:14px;
    }

    input{
        width:100%;
        padding:12px;
        border:none;
        border-radius:4px;
        background:#333;
        color:white;
        font-size:15px;
    }

    input:focus{
        outline:2px solid #e50914;
    }

    .login-btn{
        width:100%;
        padding:12px;
        margin-top:10px;
        border:none;
        border-radius:4px;
        background:#e50914;
        color:white;
        font-size:16px;
        cursor:pointer;
        font-weight:bold;
    }

    .login-btn:hover{
        background:#f6121d;
    }

    .msg-section{
        text-align:center;
        margin-top:20px;
        font-size:14px;
    }

    .success{
        color:#46d369;
    }

    .error{
        color:#e50914;
    }
</style>
</head>

<body>

<div class="navbar">
    <div class="logo">NETFLIX</div>
    <div class="nav-link">
        <a href="/login">Login</a>
        <a href="/registration">Register</a>
    </div>
</div>

<div class="container">
    <h2>Sign Up</h2>

    <form action="/registration" method="POST">
        <div class="input-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="Enter your email">
        </div>

        <div class="input-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="Enter your password">
        </div>

        <button type="submit" class="login-btn">
            Register
        </button>
    </form>

    <div class="msg-section">
        <% if(msg){ %>
            <p class="<%= msg === 'Registration Successful' ? 'success' : 'error' %>">
                <%= msg %>
            </p>
            <% if(msg === 'Registration Successful'){ %>
            <script>
                setTimeout(() => {
                    window.location.href = "/login";
                }, 2000);
            </script>
            <% } %>
        <% } %>
    </div>
</div>

</body>
</html>