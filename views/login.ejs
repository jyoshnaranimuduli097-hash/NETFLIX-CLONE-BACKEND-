<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login Page</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, Helvetica, sans-serif;
    }

    body{
        height:100vh;
        display:flex;
        justify-content:center;
        align-items:center;
        background:#121212;
    }

    .container{
        width:350px;
        background:#1e1e1e;
        padding:30px;
        border-radius:12px;
        box-shadow:0 0 15px rgba(0,0,0,0.4);
    }

    h2{
        text-align:center;
        color:white;
        margin-bottom:25px;
    }

    .input-group{
        margin-bottom:15px;
    }

    label{
        display:block;
        color:#ddd;
        margin-bottom:6px;
    }

    input{
        width:100%;
        padding:12px;
        border:none;
        border-radius:6px;
        background:#2c2c2c;
        color:white;
        font-size:15px;
    }

    input:focus{
        outline:2px solid #4CAF50;
    }

    .login-btn{
        width:100%;
        padding:12px;
        margin-top:10px;
        border:none;
        border-radius:6px;
        background:#4CAF50;
        color:white;
        font-size:16px;
        cursor:pointer;
    }

    .login-btn:hover{
        background:#43a047;
    }

    .register-section{
        text-align:center;
        margin-top:20px;
        color:#ccc;
    }

    .register-btn{
        display:inline-block;
        margin-top:10px;
        padding:10px 20px;
        text-decoration:none;
        background:#2196F3;
        color:white;
        border-radius:6px;
    }

    .register-btn:hover{
        background:#1976D2;
    }
</style>
</head>

<body>

<div class="container">
    <h2>Login</h2>

    <form action="#" method="POST">
        <div class="input-group">
            <label>Email</label>
            <input type="email" name="email" placeholder="Enter your email">
        </div>

        <div class="input-group">
            <label>Password</label>
            <input type="password" name="password" placeholder="Enter your password">
        </div>

        <button type="submit" class="login-btn">
            Login
        </button>
    </form>

    <div class="register-section">
        <p>Don't have an account?</p>
        <a href="/registration" class="register-btn">
            Register
        </a>
    </div>
    <div class="register-section" >
        <% if(msg){ %>
            <p style="color:rgba(249, 38, 38, 0.897)"><%= msg  %></p>
        <% } %>
    </div>
</div>

</body>
</html>